# AgenticStore MCP Tools — Environment Variables
#
# Copy this file to .env and fill in the keys you need.
# Only the modules you use require their respective keys.
#
# Usage with uv:
#   cp .env.example .env
#   uv run server.py

# ---------------------------------------------------------------------------
# AgenticCode (modules/code/)
# No API keys required — all tools use stdlib or free public APIs.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# AgenticData (modules/data/)
# No API keys required — uses stdlib and self-hosted services.
# ---------------------------------------------------------------------------

# URL of your self-hosted SearXNG instance (required for agentic_web_search)
# Start SearXNG: docker compose up -d
SEARXNG_URL=http://localhost:8080

# Secret key for SearXNG (set a strong random value in production)
SEARXNG_SECRET=please-change-this-secret

# ---------------------------------------------------------------------------
# AgenticSearch (modules/search/) — coming soon
# ---------------------------------------------------------------------------
# BRAVE_SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# AgenticComms (modules/comms/) — coming soon
# ---------------------------------------------------------------------------
# SENDGRID_API_KEY=
# SLACK_BOT_TOKEN=

# ---------------------------------------------------------------------------
# AgenticFinance (modules/finance/) — coming soon
# ---------------------------------------------------------------------------
# ALPHA_VANTAGE_API_KEY=

# ---------------------------------------------------------------------------
# AgenticProductivity (modules/productivity/) — coming soon
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Prompt Firewall (agentic_store_mcp/firewall/)
# The webapp sets these automatically when you click "Start Proxy".
# Uncomment to manually route external scripts through the firewall.
# ---------------------------------------------------------------------------
# ANTHROPIC_BASE_URL=http://localhost:8766
# OPENAI_BASE_URL=http://localhost:8766/openai
